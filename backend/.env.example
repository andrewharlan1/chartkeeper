DATABASE_URL=postgres://postgres:postgres@localhost:5432/chartkeeper
JWT_SECRET=change-me-to-a-long-random-string
PORT=3000

S3_BUCKET=chartkeeper-dev
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_ENDPOINT=          # optional: set for local MinIO, e.g. http://localhost:9000
PDF_MAX_SIZE_MB=50

OMR_SERVICE_URL=http://localhost:3001
OMR_POLL_INTERVAL_MS=10000
OMR_MAX_ATTEMPTS=3

DIFF_POLL_INTERVAL_MS=5000
DIFF_MAX_ATTEMPTS=3

OMR_ENGINE=audiveris    # audiveris | none (vision is legacy, quarantined)
AUDIVERIS_PATH=/Applications/Audiveris.app/Contents/MacOS/Audiveris

APN_KEY_PATH=           # path to .p8 key file
APN_KEY_ID=
APN_TEAM_ID=
APN_BUNDLE_ID=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=
